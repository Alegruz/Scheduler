# Development environment variables
# Copy to .env and customize

# Database
DATABASE_URL=postgresql://scheduler:scheduler@localhost:5432/scheduler

# Security — change this in production!
SECRET_KEY=dev-secret-key-change-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Calendar OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Scheduler settings
FREEZE_HORIZON_MINUTES=30
NIGHTLY_PLAN_HOUR=22
INTRADAY_REPAIR_INTERVAL_MINUTES=15

# Firebase Cloud Messaging (optional, for push notifications)
FCM_SERVER_KEY=

# Debug
DEBUG=false
