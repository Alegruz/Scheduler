# ──────────────────────────────────────────────────────────────────────────────
# Scheduler — .gitignore
# ──────────────────────────────────────────────────────────────────────────────
# This file tells Git which files and directories should never be tracked.
# Keep this file up to date as the technology stack evolves.
# Reference: https://github.com/github/gitignore

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE metadata ─────────────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln.docstates
*.swp
*.swo
*~
.project
.classpath
.settings/
*.iml
*.iws
*.ipr
nbproject/

# ── Secrets & environment ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ── Build artefacts ───────────────────────────────────────────────────────────
dist/
build/
out/
target/
*.class
*.o
*.so
*.dylib
*.dll
*.exe
*.jar
*.war
*.ear
*.apk
*.aab
*.ipa

# ── Dependency directories ────────────────────────────────────────────────────
node_modules/
jspm_packages/
bower_components/
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.pyo
vendor/
.bundle/
Pods/
.gradle/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
!gradlew
!gradlew.bat

# ── Logs & temporary files ────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
*.temp
tmp/
temp/
.cache/
.parcel-cache/
.next/
.nuxt/
.svelte-kit/

# ── Test & coverage artefacts ─────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
junit.xml

# ── Package manager lock files (keep whichever your project uses) ─────────────
# Uncomment the line below ONLY if you intentionally do not commit lock files.
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ── Miscellaneous ─────────────────────────────────────────────────────────────
*.bak
*.orig
*.patch
.terraform/
*.tfstate
*.tfstate.backup
